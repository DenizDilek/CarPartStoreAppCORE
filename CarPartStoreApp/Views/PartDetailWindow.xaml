<Window x:Class="CarPartStoreApp.Views.PartDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#1A202C"
        TextElement.Foreground="#E2E8F0"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True">
    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="32"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False"
            NonClientFrameEdges="None"
            GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Dark Theme Color Scheme -->
        <SolidColorBrush x:Key="HeaderBrush" Color="#2D3748"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#4A5568"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#1A202C"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#2D3748"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#4A5568"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#3D4654"/>
        <SolidColorBrush x:Key="PressedBrush" Color="#4A5568"/>
        <SolidColorBrush x:Key="TextBrush" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#A0AEC0"/>

        <!-- Custom Window Style with Dark Title Bar -->
        <Style x:Key="CustomWindowStyle" TargetType="Window">
            <Setter Property="Background" Value="#1A202C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Window">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="#2D3748"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="32"/>  <!-- Title bar height -->
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <!-- Custom Title Bar -->
                                <Grid Grid.Row="0" Background="#2D3748">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Window Icon -->
                                    <Image Grid.Column="0"
                                           Source="pack://application:,,,/CarPartStoreApp;component/Icon.png"
                                           Width="16"
                                           Height="16"
                                           Margin="12,0,8,0"
                                           VerticalAlignment="Center"/>
                                    <!-- Window Title -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Title, RelativeSource={RelativeSource TemplatedParent}}"
                                               Foreground="#FFFFFF"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="0,0,0,1"/>
                                    <!-- Window Control Buttons (Minimize, Maximize, Close) -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button x:Name="MinimizeButton"
                                                Width="46"
                                                Height="32"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="#E2E8F0"
                                                WindowChrome.IsHitTestVisibleInChrome="True"
                                                Click="Minimize_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#3D4654"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            Width="46"
                                                            Height="32"
                                                            CornerRadius="0">
                                                        <TextBlock Text="─"
                                                                   FontSize="10"
                                                                   Foreground="#E2E8F0"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button x:Name="MaximizeButton"
                                                Width="46"
                                                Height="32"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="#E2E8F0"
                                                WindowChrome.IsHitTestVisibleInChrome="True"
                                                Click="Maximize_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#3D4654"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            Width="46"
                                                            Height="32"
                                                            CornerRadius="0">
                                                        <TextBlock Text="□"
                                                                   FontSize="10"
                                                                   Foreground="#E2E8F0"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button x:Name="CloseButton"
                                                Width="46"
                                                Height="32"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="#E2E8F0"
                                                WindowChrome.IsHitTestVisibleInChrome="True"
                                                Click="Close_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#E53E3E"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            Width="46"
                                                            Height="32"
                                                            CornerRadius="8,0,0,0">
                                                        <TextBlock Text="✕"
                                                                   FontSize="10"
                                                                   Foreground="#E2E8F0"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                                <!-- Window Content -->
                                <ContentPresenter Grid.Row="1"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar Style (Dark Theme with Rounded Corners) -->
        <Style x:Key="ModernScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="MinWidth" Value="10"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Margin="0,2,0,2">
                                <Track.Thumb>
                                    <Thumb MinWidth="10">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder"
                                                        Background="#4A5568"
                                                        CornerRadius="5"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#5A6578" TargetName="ThumbBorder"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Horizontal ScrollBar Style (Dark Theme with Rounded Corners) -->
        <Style x:Key="ModernHorizontalScrollBar" TargetType="ScrollBar" BasedOn="{StaticResource ModernScrollBar}">
            <Setter Property="MinHeight" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="False"
                                   Margin="2,0,2,0">
                                <Track.Thumb>
                                    <Thumb MinHeight="10">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder"
                                                        Background="#4A5568"
                                                        CornerRadius="5"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#5A6578" TargetName="ThumbBorder"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Implicit ScrollBar Style - applies to all ScrollBar controls by default -->
        <!-- We use a trigger-based approach instead of BasedOn to handle orientation properly -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="MinWidth" Value="10"/>
                    <Setter Property="Width" Value="10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid>
                                    <Track x:Name="PART_Track"
                                           IsDirectionReversed="True"
                                           Margin="0,2,0,2">
                                        <Track.Thumb>
                                            <Thumb MinWidth="10">
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border x:Name="ThumbBorder"
                                                                Background="#4A5568"
                                                                CornerRadius="5"/>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#5A6578" TargetName="ThumbBorder"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="MinHeight" Value="10"/>
                    <Setter Property="Height" Value="10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid>
                                    <Track x:Name="PART_Track"
                                           IsDirectionReversed="False"
                                           Margin="2,0,2,0">
                                        <Track.Thumb>
                                            <Thumb MinHeight="10">
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border x:Name="ThumbBorder"
                                                                Background="#4A5568"
                                                                CornerRadius="5"/>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#5A6578" TargetName="ThumbBorder"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ScrollViewer Style (Dark Theme) -->
        <Style x:Key="ModernScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Background" Value="#1A202C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter Grid.Column="0" Grid.Row="0"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Column="1"
                                       Orientation="Vertical"
                                       Style="{StaticResource ModernScrollBar}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{TemplateBinding VerticalOffset}"/>
                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                       Grid.Row="1"
                                       Orientation="Horizontal"
                                       Style="{StaticResource ModernHorizontalScrollBar}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Value="{TemplateBinding HorizontalOffset}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button Style (Dark Theme) -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#3182CE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4299E1"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#4A5568"/>
                    <Setter Property="Foreground" Value="#A0AEC0"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#2D3748"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#4A5568"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D4654"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#1A202C"/>
                    <Setter Property="BorderBrush" Value="#2D3748"/>
                    <Setter Property="Foreground" Value="#4A5568"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- GroupBox Style (Dark Theme) -->
        <Style x:Key="ModernGroupBox" TargetType="GroupBox">
            <Setter Property="Background" Value="#2D3748"/>
            <Setter Property="BorderBrush" Value="#4A5568"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.2" BlurRadius="8" ShadowDepth="2"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <ContentPresenter Grid.Row="0" ContentSource="Header" Margin="8,0,8,12"/>
                                <ContentPresenter Grid.Row="1" VerticalAlignment="Stretch"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GroupBox Header Style (Dark Theme) -->
        <Style x:Key="GroupBoxHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>

        <!-- Label Style (Dark Theme) -->
        <Style x:Key="ModernLabel" TargetType="Label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Custom Title Bar -->
        <Border DockPanel.Dock="Top" Background="#2D3748" Height="32" x:Name="TitleBar">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Window Icon -->
                <Image Grid.Column="0"
                       Source="pack://application:,,,/CarPartStoreApp;component/Icon.png"
                       Width="16"
                       Height="16"
                       Margin="12,0,8,0"
                       VerticalAlignment="Center"/>
                <!-- Window Title -->
                <TextBlock Grid.Column="1"
                           Text="{Binding Title}"
                           Foreground="#FFFFFF"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,0,1"/>
                <!-- Window Control Buttons (Minimize, Maximize, Close) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="MinimizeButton"
                            Width="46"
                            Height="32"
                            BorderThickness="0"
                            Foreground="#E2E8F0"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Focusable="False"
                            Click="Minimize_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ButtonBorder"
                                                    Background="{TemplateBinding Background}"
                                                    Width="46"
                                                    Height="32"
                                                    CornerRadius="0">
                                                <TextBlock Text="─"
                                                           FontSize="14"
                                                           Foreground="#FFFFFF"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,0,4"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" TargetName="ButtonBorder" Value="#3D4654"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="MaximizeButton"
                            Width="46"
                            Height="32"
                            BorderThickness="0"
                            Foreground="#E2E8F0"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Focusable="False"
                            Click="Maximize_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ButtonBorder"
                                                    Background="{TemplateBinding Background}"
                                                    Width="46"
                                                    Height="32"
                                                    CornerRadius="0">
                                                <TextBlock Text="□"
                                                           FontSize="10"
                                                           Foreground="#FFFFFF"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" TargetName="ButtonBorder" Value="#3D4654"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="CloseButton"
                            Width="46"
                            Height="32"
                            BorderThickness="0"
                            Foreground="#E2E8F0"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Focusable="False"
                            Click="Close_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ButtonBorder"
                                                    Background="{TemplateBinding Background}"
                                                    Width="46"
                                                    Height="32"
                                                    CornerRadius="0">
                                                <TextBlock Text="✕"
                                                           FontSize="12"
                                                           Foreground="#FFFFFF"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" TargetName="ButtonBorder" Value="#E53E3E"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Padding="0" Style="{StaticResource ModernScrollViewer}">
            <Border Background="#2D3748"
                    BorderBrush="#4A5568"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="24,24,24,0"
                    Padding="24">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.2" BlurRadius="12" ShadowDepth="2"/>
                </Border.Effect>

                <StackPanel>
                    <!-- Header Section -->
                    <TextBlock Text="{Binding Part.Name}"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#E2E8F0"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="{Binding Part.PartNumber}"
                               FontSize="14"
                               Foreground="#A0AEC0"
                               Margin="0,0,0,24"/>

                    <!-- Details GroupBox -->
                    <GroupBox Style="{StaticResource ModernGroupBox}" Margin="0,0,0,16">
                        <GroupBox.Header>
                            <TextBlock Text="Part Details" Style="{StaticResource GroupBoxHeaderStyle}"/>
                        </GroupBox.Header>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Part Number -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding LabelPartNumber}"
                                       Foreground="#A0AEC0" Margin="0,0,0,8" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Part.PartNumber}"
                                       Foreground="#E2E8F0" Margin="0,0,0,12" VerticalAlignment="Center"/>

                            <!-- Category -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding LabelCategory}"
                                       Foreground="#A0AEC0" Margin="0,0,0,8" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Part.CategoryName}"
                                       Foreground="#E2E8F0" Margin="0,0,0,12" VerticalAlignment="Center"/>

                            <!-- Brand -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding LabelBrand}"
                                       Foreground="#A0AEC0" Margin="0,0,0,8" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Part.Brand}"
                                       Foreground="#E2E8F0" Margin="0,0,0,12" VerticalAlignment="Center"/>
                        </Grid>
                    </GroupBox>

                    <!-- More Details GroupBox -->
                    <GroupBox Style="{StaticResource ModernGroupBox}" Margin="0,0,0,16">
                        <GroupBox.Header>
                            <TextBlock Text="Additional Information" Style="{StaticResource GroupBoxHeaderStyle}"/>
                        </GroupBox.Header>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Cost Price -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding LabelCostPrice}"
                                       Foreground="#A0AEC0" Margin="0,0,0,8" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Part.CostPrice, StringFormat=C}"
                                       Foreground="#E2E8F0" Margin="0,0,0,12" VerticalAlignment="Center"/>

                            <!-- Stock Quantity -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding LabelStockQuantity}"
                                       Foreground="#A0AEC0" Margin="0,0,0,8" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Part.StockQuantity}"
                                       Foreground="#E2E8F0" Margin="0,0,0,12" VerticalAlignment="Center"/>

                            <!-- Location -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding LabelLocation}"
                                       Foreground="#A0AEC0" Margin="0,0,0,8" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Part.Location}"
                                       Foreground="#E2E8F0" Margin="0,0,0,12" VerticalAlignment="Center"/>

                            <!-- Model -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding LabelModel}"
                                       Foreground="#A0AEC0" Margin="0,0,0,8" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Part.Model}"
                                       Foreground="#E2E8F0" Margin="0,0,0,12" VerticalAlignment="Center"/>

                            <!-- Release Date -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding LabelReleaseDate}"
                                       Foreground="#A0AEC0" Margin="0,0,0,8" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Part.ReleaseDate}"
                                       Foreground="#E2E8F0" Margin="0,0,0,12" VerticalAlignment="Center"/>
                        </Grid>
                    </GroupBox>

                    <!-- Description GroupBox -->
                    <GroupBox Style="{StaticResource ModernGroupBox}" Margin="0,0,0,16">
                        <GroupBox.Header>
                            <TextBlock Text="{Binding LabelDescription}" Style="{StaticResource GroupBoxHeaderStyle}"/>
                        </GroupBox.Header>
                        <TextBlock Text="{Binding Part.Description}"
                                   Foreground="#E2E8F0"
                                   TextWrapping="Wrap"/>
                    </GroupBox>

                    <!-- Images Section -->
                    <GroupBox Style="{StaticResource ModernGroupBox}" Margin="0,0,0,16">
                        <GroupBox.Header>
                            <TextBlock Text="{Binding ImagesTitle}" Style="{StaticResource GroupBoxHeaderStyle}"/>
                        </GroupBox.Header>

                        <StackPanel>
                            <!-- Main Image Viewer Frame -->
                            <Border Background="#1A202C"
                                    BorderBrush="#4A5568"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="0,0,0,16">
                                <Grid>
                                    <!-- Main Display Area -->
                                    <Image Source="{Binding SelectedImage.ImagePath}"
                                           Stretch="Uniform"
                                           MaxHeight="400"
                                           x:Name="MainImageDisplay"/>
                                </Grid>
                            </Border>

                            <!-- Thumbnail Strip -->
                            <ItemsControl ItemsSource="{Binding PartImages}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#2D3748"
                                                BorderBrush="#4A5568"
                                                BorderThickness="2"
                                                CornerRadius="6"
                                                Padding="8"
                                                Margin="0,0,8,0"
                                                Width="80"
                                                Height="80"
                                                Cursor="Hand">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#2D3748"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="#3182CE"/>
                                                            <Setter Property="BorderBrush" Value="#3182CE"/>
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#3D4654"/>
                                                            <Setter Property="BorderBrush" Value="#63B3ED"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <Button Command="{Binding DataContext.SelectImageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Width="64"
                                                    Height="64"
                                                    Background="Transparent"
                                                    Foreground="Transparent"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Padding="0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Image Source="{Binding ImagePath}"
                                                               Stretch="Uniform"
                                                               MaxHeight="64"
                                                               MaxWidth="64"
                                                               Margin="4"/>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </GroupBox>

                    <!-- Close Button -->
                    <Button Content="{Binding CloseButton}"
                            Click="Close_Click"
                            Width="120"
                            Height="36"
                            HorizontalAlignment="Right"
                            Style="{StaticResource ModernButton}"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </DockPanel>
</Window>
