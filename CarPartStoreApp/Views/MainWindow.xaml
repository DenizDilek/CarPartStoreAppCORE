<Window x:Class="CarPartStoreApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CarPartStoreApp"
        xmlns:converters="clr-namespace:CarPartStoreApp.Converters"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="650" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#1A202C"
        TextElement.Foreground="#E2E8F0">
    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="32"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False"
            NonClientFrameEdges="None"
            GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <!-- Converters -->
        <converters:FirstImageConverter x:Key="FirstImageConverter"/>
        <!-- Dark Theme Color Scheme -->
        <SolidColorBrush x:Key="HeaderBrush" Color="#2D3748"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#4A5568"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#1A202C"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#2D3748"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#4A5568"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#3D4654"/>
        <SolidColorBrush x:Key="PressedBrush" Color="#4A5568"/>
        <SolidColorBrush x:Key="TextBrush" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#A0AEC0"/>
        <Style x:Key="CustomWindowStyle" TargetType="Window">
            <Setter Property="Background" Value="#1A202C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Window">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="#2D3748"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="32"/>  <!-- Title bar height -->
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <!-- Custom Title Bar -->
                                <Grid Grid.Row="0" Background="#2D3748">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Window Icon -->
                                    <Image Grid.Column="0"
                                           Source="pack://application:,,,/CarPartStoreApp;component/Icon.png"
                                           Width="16"
                                           Height="16"
                                           Margin="12,0,8,0"
                                           VerticalAlignment="Center"/>
                                    <!-- Window Title -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Title, RelativeSource={RelativeSource TemplatedParent}}"
                                               Foreground="#FFFFFF"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="0,0,0,1"/>
                                    <!-- Window Control Buttons (Minimize, Maximize, Close) -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button x:Name="MinimizeButton"
                                                Width="46"
                                                Height="32"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="#E2E8F0"
                                                WindowChrome.IsHitTestVisibleInChrome="True"
                                                Click="Minimize_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#3D4654"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            Width="46"
                                                            Height="32"
                                                            CornerRadius="0">
                                                        <TextBlock Text="─"
                                                                   FontSize="10"
                                                                   Foreground="#E2E8F0"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button x:Name="MaximizeButton"
                                                Width="46"
                                                Height="32"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="#E2E8F0"
                                                WindowChrome.IsHitTestVisibleInChrome="True"
                                                Click="Maximize_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#3D4654"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            Width="46"
                                                            Height="32"
                                                            CornerRadius="0">
                                                        <TextBlock Text="□"
                                                                   FontSize="10"
                                                                   Foreground="#E2E8F0"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button x:Name="CloseButton"
                                                Width="46"
                                                Height="32"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="#E2E8F0"
                                                WindowChrome.IsHitTestVisibleInChrome="True"
                                                Click="Close_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#E53E3E"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            Width="46"
                                                            Height="32"
                                                            CornerRadius="8,0,0,0">
                                                        <TextBlock Text="✕"
                                                                   FontSize="10"
                                                                   Foreground="#E2E8F0"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                                <!-- Window Content -->
                                <ContentPresenter Grid.Row="1"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar Style (Dark Theme with Rounded Corners) -->
        <Style x:Key="ModernScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="MinWidth" Value="10"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Margin="0,2,0,2">
                                <Track.Thumb>
                                    <Thumb MinWidth="10">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder"
                                                        Background="#4A5568"
                                                        CornerRadius="5"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#5A6578" TargetName="ThumbBorder"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Horizontal ScrollBar Style (Dark Theme with Rounded Corners) -->
        <Style x:Key="ModernHorizontalScrollBar" TargetType="ScrollBar" BasedOn="{StaticResource ModernScrollBar}">
            <Setter Property="MinHeight" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="False"
                                   Margin="2,0,2,0">
                                <Track.Thumb>
                                    <Thumb MinHeight="10">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder"
                                                        Background="#4A5568"
                                                        CornerRadius="5"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#5A6578" TargetName="ThumbBorder"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Implicit ScrollBar Style - applies to all ScrollBar controls by default -->
        <!-- We use a trigger-based approach instead of BasedOn to handle orientation properly -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="MinWidth" Value="10"/>
                    <Setter Property="Width" Value="10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid>
                                    <Track x:Name="PART_Track"
                                           IsDirectionReversed="True"
                                           Margin="0,2,0,2">
                                        <Track.Thumb>
                                            <Thumb MinWidth="10">
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border x:Name="ThumbBorder"
                                                                Background="#4A5568"
                                                                CornerRadius="5"/>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#5A6578" TargetName="ThumbBorder"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="MinHeight" Value="10"/>
                    <Setter Property="Height" Value="10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid>
                                    <Track x:Name="PART_Track"
                                           IsDirectionReversed="False"
                                           Margin="2,0,2,0">
                                        <Track.Thumb>
                                            <Thumb MinHeight="10">
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border x:Name="ThumbBorder"
                                                                Background="#4A5568"
                                                                CornerRadius="5"/>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#5A6578" TargetName="ThumbBorder"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ScrollViewer Style (Dark Theme) -->
        <Style x:Key="ModernScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Background" Value="#1A202C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter Grid.Column="0" Grid.Row="0"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Column="1"
                                       Orientation="Vertical"
                                       Style="{StaticResource ModernScrollBar}"/>
                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                       Grid.Row="1"
                                       Orientation="Horizontal"
                                       Style="{StaticResource ModernHorizontalScrollBar}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button Style (Dark Theme) -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#3182CE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4299E1"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#4A5568"/>
                    <Setter Property="Foreground" Value="#A0AEC0"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#2D3748"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#4A5568"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D4654"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#1A202C"/>
                    <Setter Property="BorderBrush" Value="#2D3748"/>
                    <Setter Property="Foreground" Value="#4A5568"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- GroupBox Style (Dark Theme) -->
        <Style x:Key="ModernGroupBox" TargetType="GroupBox">
            <Setter Property="Background" Value="#2D3748"/>
            <Setter Property="BorderBrush" Value="#4A5568"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.2" BlurRadius="8" ShadowDepth="2"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <ContentPresenter Grid.Row="0" ContentSource="Header" Margin="8,0,8,12"/>
                                <ContentPresenter Grid.Row="1"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GroupBox Header Style (Dark Theme) -->
        <Style x:Key="GroupBoxHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>

        <!-- TextBox Style (Dark Theme) -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1A202C"/>
            <Setter Property="BorderBrush" Value="#4A5568"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#E2E8F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Style="{StaticResource ModernScrollViewer}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3182CE"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox Style (Dark Theme) - Fixed to allow dropdown -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#1A202C"/>
            <Setter Property="BorderBrush" Value="#4A5568"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="IsEditable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"
                                                      Margin="0"/>
                                    <ToggleButton Grid.Column="1"
                                                  x:Name="ArrowButton"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  ClickMode="Press"
                                                  Focusable="False"
                                                  Padding="8,0,4,0"
                                                  Cursor="Hand"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <Path x:Name="Arrow"
                                              Width="10"
                                              Height="6"
                                              Fill="#A0AEC0"
                                              Stretch="Uniform"
                                              Data="M0,0 L5,6 L10,0"/>
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border x:Name="ArrowButtonBorder"
                                                                    Background="{TemplateBinding Background}"
                                                                    Padding="{TemplateBinding Padding}"
                                                                    Cursor="{TemplateBinding Cursor}"
                                                                    CornerRadius="0,6,6,0">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#2D3748" TargetName="ArrowButtonBorder"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <!-- Popup for dropdown -->
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="False"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="PopupBorder"
                                        Background="#2D3748"
                                        BorderBrush="#4A5568"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="4"
                                        MaxHeight="200"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer Style="{StaticResource ModernScrollViewer}">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3182CE" TargetName="Border"/>
                                <Setter Property="BorderThickness" Value="2" TargetName="Border"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Fill" Value="#E2E8F0" TargetName="Arrow"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter Property="Fill" Value="#3182CE" TargetName="Arrow"/>
                                <Setter Property="BorderBrush" Value="#3182CE" TargetName="Border"/>
                                <Setter Property="BorderThickness" Value="2" TargetName="Border"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#E2E8F0"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBorder"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}"
                                            CornerRadius="4"
                                            Margin="2">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3D4654" TargetName="ItemBorder"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#3182CE" TargetName="ItemBorder"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label Style (Dark Theme) -->
        <Style x:Key="ModernLabel" TargetType="Label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- SubMenuItem Style for ContextMenu and dropdowns -->
        <Style x:Key="SubMenuItem" TargetType="MenuItem">
            <Setter Property="Padding" Value="24,6,8,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4"
                                Margin="2">
                            <Grid>
                                <ContentPresenter Content="{TemplateBinding Header}"
                                                ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#3D4654" TargetName="Border"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3182CE" TargetName="Border"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Menu Style (Dark Theme) -->
        <Style x:Key="ModernMenu" TargetType="Menu">
            <Setter Property="Background" Value="#2D3748"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Menu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="0">
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- MenuItem Top-Level Style (Dark Theme) -->
        <Style x:Key="ModernMenuItem" TargetType="MenuItem">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <ContentPresenter Content="{TemplateBinding Header}"
                                                ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                ContentTemplateSelector="{TemplateBinding HeaderTemplateSelector}"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left"/>
                                <Popup x:Name="PART_Popup"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       Placement="Bottom"
                                       PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                       PopupAnimation="Slide"
                                       AllowsTransparency="False"
                                       Focusable="False">
                                    <Border Background="#2D3748"
                                            BorderBrush="#4A5568"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="4"
                                            MaxHeight="400"
                                            MinWidth="180">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3182CE"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter Property="Background" Value="#3182CE"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="MenuItem" BasedOn="{StaticResource SubMenuItem}"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid Style (Dark Theme) -->
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#1A202C"/>
            <Setter Property="BorderBrush" Value="#4A5568"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowBackground" Value="#1A202C"/>
            <Setter Property="AlternatingRowBackground" Value="#232D3D"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#4A5568"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
        </Style>

        <!-- DataGrid Header Style (Dark Theme) -->
        <Style x:Key="DataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2D3748"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="#4A5568"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- DataGrid Row Style (Dark Theme) -->
        <Style x:Key="DataGridRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D3748"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3182CE"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid Cell Style (Dark Theme) -->
        <Style x:Key="DataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#4A5568"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Hint Text Style (Dark Theme) -->
        <Style x:Key="HintTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#718096"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="12,0,0,0"/>
        </Style>

        <!-- ContextMenu Style (Dark Theme) -->
        <Style x:Key="ModernContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="#2D3748"/>
            <Setter Property="BorderBrush" Value="#4A5568"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="4"
                                MaxHeight="400">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Language Selection MenuItem Style (Dark Theme with Radio Button Appearance) -->
        <Style x:Key="LanguageMenuItem" TargetType="MenuItem">
            <Setter Property="Background" Value="#2D3748"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Padding" Value="24,6,8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4"
                                Margin="2">
                            <ContentPresenter Content="{TemplateBinding Header}"
                                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#3D4654" TargetName="Border"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3D4654" TargetName="Border"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Custom Title Bar -->
        <Border DockPanel.Dock="Top" Background="#2D3748" Height="32" x:Name="TitleBar">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Window Icon -->
                <Image Grid.Column="0"
                       Source="pack://application:,,,/CarPartStoreApp;component/Icon.png"
                       Width="16"
                       Height="16"
                       Margin="12,0,8,0"
                       VerticalAlignment="Center"/>
                <!-- Window Title -->
                <TextBlock Grid.Column="1"
                           Text="{Binding Title}"
                           Foreground="#FFFFFF"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,0,1"/>
                <!-- Window Control Buttons (Minimize, Maximize, Close) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="MinimizeButton"
                            Width="46"
                            Height="32"
                            BorderThickness="0"
                            Foreground="#E2E8F0"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Focusable="False"
                            Click="Minimize_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ButtonBorder"
                                                    Background="{TemplateBinding Background}"
                                                    Width="46"
                                                    Height="32"
                                                    CornerRadius="0">
                                                <TextBlock Text="─"
                                                           FontSize="14"
                                                           Foreground="#FFFFFF"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,0,4"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" TargetName="ButtonBorder" Value="#3D4654"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="MaximizeButton"
                            Width="46"
                            Height="32"
                            BorderThickness="0"
                            Foreground="#E2E8F0"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Focusable="False"
                            Click="Maximize_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ButtonBorder"
                                                    Background="{TemplateBinding Background}"
                                                    Width="46"
                                                    Height="32"
                                                    CornerRadius="0">
                                                <TextBlock Text="□"
                                                           FontSize="10"
                                                           Foreground="#FFFFFF"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" TargetName="ButtonBorder" Value="#3D4654"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="CloseButton"
                            Width="46"
                            Height="32"
                            BorderThickness="0"
                            Foreground="#E2E8F0"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Focusable="False"
                            Click="Close_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ButtonBorder"
                                                    Background="{TemplateBinding Background}"
                                                    Width="46"
                                                    Height="32"
                                                    CornerRadius="0">
                                                <TextBlock Text="✕"
                                                           FontSize="12"
                                                           Foreground="#FFFFFF"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" TargetName="ButtonBorder" Value="#E53E3E"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top" Style="{StaticResource ModernMenu}">
            <MenuItem Header="{Binding MenuFile}" Style="{StaticResource ModernMenuItem}">
                <MenuItem Header="{Binding MenuAddPart}" Command="{Binding AddPartCommand}" Style="{StaticResource SubMenuItem}">
                    <MenuItem.Icon>
                        <TextBlock Text="➕" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{Binding MenuTest}" Command="{Binding TestPartCommand}" Style="{StaticResource SubMenuItem}">
                    <MenuItem.Icon>
                        <TextBlock Text="🧪" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator Background="#4A5568"/>
                <MenuItem Header="{Binding MenuExit}" Click="Exit_Click" Style="{StaticResource SubMenuItem}">
                    <MenuItem.Icon>
                        <TextBlock Text="🚪" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="{Binding MenuEdit}" Style="{StaticResource ModernMenuItem}">
                <MenuItem Header="{Binding MenuDeletePart}" Command="{Binding DeletePartCommand}" Style="{StaticResource SubMenuItem}">
                    <MenuItem.Icon>
                        <TextBlock Text="🗑️" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="{Binding MenuHelp}" Style="{StaticResource ModernMenuItem}">
                <MenuItem Header="{Binding Language}" Style="{StaticResource ModernMenuItem}">
                        <MenuItem Header="{Binding LanguageEnglish}" Command="{Binding ChangeLanguageCommand}" CommandParameter="en">
                            <MenuItem.Style>
                                <Style TargetType="MenuItem" BasedOn="{StaticResource LanguageMenuItem}">
                                    <Setter Property="IsChecked" Value="False"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentLanguage}" Value="en">
                                            <Setter Property="IsChecked" Value="True"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </MenuItem.Style>
                        </MenuItem>
                        <MenuItem Header="{Binding LanguageTurkish}" Command="{Binding ChangeLanguageCommand}" CommandParameter="tr">
                            <MenuItem.Style>
                                <Style TargetType="MenuItem" BasedOn="{StaticResource LanguageMenuItem}">
                                    <Setter Property="IsChecked" Value="False"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentLanguage}" Value="tr">
                                            <Setter Property="IsChecked" Value="True"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </MenuItem.Style>
                        </MenuItem>
                    </MenuItem>
                    <Separator Background="#4A5568"/>
                        <MenuItem Header="{Binding About}" Click="About_Click" Style="{StaticResource SubMenuItem}">
                            <MenuItem.Icon>
                                <TextBlock Text="ℹ️" FontSize="14"/>
                            </MenuItem.Icon>
                        </MenuItem>
                </MenuItem>
        </Menu>

        <!-- API Server Status Indicator -->
        <Menu DockPanel.Dock="Right" Style="{StaticResource ModernMenu}">
            <MenuItem Header="API Server" Style="{StaticResource ModernMenuItem}">
                <MenuItem Header="Status: Running" Style="{StaticResource SubMenuItem}">
                    <MenuItem.Icon>
                        <TextBlock Text="🟢" FontSize="12" Margin="0,0,0,0"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="URL: http://localhost:5000" FontSize="11" Foreground="#A0AEC0" FontStyle="Italic" Style="{StaticResource SubMenuItem}"/>
            </MenuItem>
        </Menu>

        <!-- Main Content -->
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Search and Filter Panel -->
            <GroupBox Grid.Row="0" Margin="0,0,0,16" Style="{StaticResource ModernGroupBox}">
                <GroupBox.Header>
                    <TextBlock Text="{Binding SearchGroupBox}" Style="{StaticResource GroupBoxHeaderStyle}"/>
                </GroupBox.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Search Box (Full Width) -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <Label Content="{Binding SearchLabel}" Width="100" Style="{StaticResource ModernLabel}"/>
                        <TextBox Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}" Width="600" Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>

                    <!-- Row 1: Category (Left) | Brand (Right) -->
                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Category Filter -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Label Content="{Binding CategoryLabel}" Width="100" Style="{StaticResource ModernLabel}"/>
                            <ComboBox ItemsSource="{Binding Categories}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding SelectedCategory}"
                                      Width="220" Style="{StaticResource ModernComboBox}"/>
                        </StackPanel>

                        <!-- Brand Filter -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Label Content="{Binding BrandLabel}" Width="100" Style="{StaticResource ModernLabel}"/>
                            <ComboBox ItemsSource="{Binding Brands}"
                                      SelectedItem="{Binding SelectedBrand}"
                                      Width="220" Style="{StaticResource ModernComboBox}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row 2: Year (Left) | Model (Right) -->
                    <Grid Grid.Row="2" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Year Filter -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Label Content="{Binding YearLabel}" Width="100" Style="{StaticResource ModernLabel}"/>
                            <ComboBox ItemsSource="{Binding Years}"
                                      SelectedItem="{Binding SelectedYear}"
                                      Width="220" Style="{StaticResource ModernComboBox}"/>
                        </StackPanel>

                        <!-- Model Filter -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Label Content="{Binding ModelLabel}" Width="100" Style="{StaticResource ModernLabel}"/>
                            <ComboBox ItemsSource="{Binding Models}"
                                      SelectedItem="{Binding SelectedModel}"
                                      Width="220" Style="{StaticResource ModernComboBox}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row 3: Database (Left) | Buttons (Right) -->
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Database Selection -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Label Content="{Binding DatabaseLabel}" Width="100" Style="{StaticResource ModernLabel}"/>
                            <ComboBox ItemsSource="{Binding DatabaseTypes}"
                                      SelectedItem="{Binding SelectedDatabase}"
                                      Width="220" Style="{StaticResource ModernComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#E2E8F0"/>
                                                    <Setter Property="Text" Value="{Binding DataContext.DatabaseLocal, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="Cloud">
                                                            <Setter Property="Text" Value="{Binding DataContext.DatabaseCloud, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <!-- Search and Reset Buttons -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="{Binding ButtonSearch}"
                                    Width="100"
                                    Height="32"
                                    Margin="0,0,8,0"
                                    Command="{Binding SearchCommand}"
                                    Style="{StaticResource ModernButton}"
                                    ToolTip="{Binding ToolTipSearch}"/>
                            <Button Content="{Binding ButtonReset}"
                                    Width="120"
                                    Height="32"
                                    Command="{Binding ResetCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    ToolTip="{Binding ToolTipReset}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </GroupBox>

            <!-- Parts Data Grid -->
            <GroupBox Grid.Row="1" Style="{StaticResource ModernGroupBox}">
                <GroupBox.Header>
                    <TextBlock Text="{Binding InventoryGroupBox}" Style="{StaticResource GroupBoxHeaderStyle}"/>
                </GroupBox.Header>
                <DataGrid x:Name="PartsDataGrid"
                          ItemsSource="{Binding Parts}"
                          SelectedItem="{Binding SelectedPart}"
                          Style="{StaticResource ModernDataGrid}"
                          ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                          RowStyle="{StaticResource DataGridRowStyle}"
                          CellStyle="{StaticResource DataGridCellStyle}">
                <DataGrid.ContextMenu>
                    <ContextMenu Style="{StaticResource ModernContextMenu}">
                        <MenuItem Header="{Binding ContextMenuDisplay}" Command="{Binding ShowPartDetailCommand}" Style="{StaticResource SubMenuItem}">
                            <MenuItem.Icon>
                                <TextBlock Text="🔍" FontSize="14"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{Binding ContextMenuEdit}" Command="{Binding EditPartCommand}" Style="{StaticResource SubMenuItem}">
                            <MenuItem.Icon>
                                <TextBlock Text="✏️" FontSize="14"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator Background="#4A5568"/>
                        <MenuItem Header="{Binding ContextMenuDelete}" Command="{Binding DeletePartCommand}" Style="{StaticResource SubMenuItem}">
                            <MenuItem.Icon>
                                <TextBlock Text="🗑️" FontSize="14"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </DataGrid.ContextMenu>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Part #" Binding="{Binding PartNumber}" Width="110"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="240"/>
                    <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="110"/>
                    <DataGridTextColumn Header="Cost" Binding="{Binding CostPrice, StringFormat='C2'}" Width="80"/>
                    <DataGridTextColumn Header="Retail" Binding="{Binding RetailPrice, StringFormat='C2'}" Width="80"/>
                    <DataGridTextColumn Header="Stock" Binding="{Binding StockQuantity}" Width="65"/>
                    <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="110"/>
                    <DataGridTextColumn Header="Supplier" Binding="{Binding Supplier}" Width="130"/>
                    <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="100"/>
                    <DataGridTextColumn Header="Year" Binding="{Binding ReleaseDate}" Width="80"/>
                    <DataGridTemplateColumn Width="100" Header="Image">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#4A5568" BorderThickness="1" Background="#1A202C" Width="80" Height="50" Margin="4" CornerRadius="4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Border.Background" Value="#1A202C"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ImagePath}" Value="">
                                                    <Setter Property="Border.Background" Value="#232D3D"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ImagePath}" Value="{x:Null}">
                                                    <Setter Property="Border.Background" Value="#232D3D"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Image Source="{Binding ImagePath, Converter={StaticResource FirstImageConverter}}" Stretch="Uniform" Margin="6">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ImagePath}" Value="">
                                                        <Setter Property="Image.Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ImagePath}" Value="{x:Null}">
                                                        <Setter Property="Image.Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
        </Grid>
    </DockPanel>
</Window>
