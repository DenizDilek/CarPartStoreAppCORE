<Window x:Class="CarPartStoreApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CarPartStoreApp"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="600" Width="1000">
    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="{Binding MenuFile}">
                <MenuItem Header="{Binding MenuAddPart}" Command="{Binding AddPartCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="➕" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{Binding MenuExit}" Click="Exit_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="🚪" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="{Binding MenuEdit}">
                <MenuItem Header="{Binding MenuDeletePart}" Command="{Binding DeletePartCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="🗑️" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="{Binding MenuHelp}">
                <MenuItem Header="{Binding Language}">
                        <MenuItem Header="{Binding LanguageEnglish}" Command="{Binding ChangeLanguageCommand}" CommandParameter="en">
                            <MenuItem.Style>
                                <Style TargetType="MenuItem">
                                    <Setter Property="IsChecked" Value="False"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentLanguage}" Value="en">
                                            <Setter Property="IsChecked" Value="True"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </MenuItem.Style>
                        </MenuItem>
                        <MenuItem Header="{Binding LanguageTurkish}" Command="{Binding ChangeLanguageCommand}" CommandParameter="tr">
                            <MenuItem.Style>
                                <Style TargetType="MenuItem">
                                    <Setter Property="IsChecked" Value="False"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentLanguage}" Value="tr">
                                            <Setter Property="IsChecked" Value="True"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </MenuItem.Style>
                        </MenuItem>
                    </MenuItem>
                    <Separator/>
                        <MenuItem Header="{Binding About}" Click="About_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="ℹ️" FontSize="14"/>
                            </MenuItem.Icon>
                        </MenuItem>
                </MenuItem>
        </Menu>
        <!-- API Server Status Indicator -->
        <Menu DockPanel.Dock="Right">
            <MenuItem Header="API Server">
                <MenuItem Header="Status: Running">
                    <MenuItem.Icon>
                        <TextBlock Text="🟢" FontSize="12" Margin="0,0,0,0"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="URL: http://localhost:5000" FontSize="11" Foreground="Gray" FontStyle="Italic"/>
            </MenuItem>
        </Menu>
        <!-- Main Content -->
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Search and Filter Panel -->
            <GroupBox Grid.Row="0" Header="{Binding SearchGroupBox}" Margin="0,0,10,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Search Box -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Label Content="{Binding SearchLabel}" Width="80" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}" Width="300" Height="25" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SearchHint}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="Gray" FontSize="11"/>
                    </StackPanel>
                    <!-- Category Filter -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Label Content="{Binding CategoryLabel}" Width="80" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding Categories}"
                                  DisplayMemberPath="Name"
                                  SelectedItem="{Binding SelectedCategory}"
                                  Width="300" Height="25" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CategoryHint}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="Gray" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- Parts Data Grid -->
            <GroupBox Grid.Row="1" Header="{Binding InventoryGroupBox}" Margin="0,10,10,0">
                <DataGrid x:Name="PartsDataGrid"
                          ItemsSource="{Binding Parts}"
                          SelectedItem="{Binding SelectedPart}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          GridLinesVisibility="All"
                          HeadersVisibility="Column"
                          RowBackground="White"
                          AlternatingRowBackground="#F5F5F5">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{Binding ContextMenuEdit}" Command="{Binding EditPartCommand}">
                            <MenuItem.Icon>
                                <TextBlock Text="✏️" FontSize="14"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Header="{Binding ContextMenuDelete}" Command="{Binding DeletePartCommand}">
                            <MenuItem.Icon>
                                <TextBlock Text="🗑️" FontSize="14"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </DataGrid.ContextMenu>

                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding PartNumber}" Width="120"/>
                    <DataGridTextColumn Binding="{Binding Name}" Width="200"/>
                    <DataGridTextColumn Binding="{Binding Description}" Width="250"/>
                    <DataGridTextColumn Binding="{Binding CategoryName}" Width="120"/>
                    <DataGridTextColumn Binding="{Binding CostPrice, StringFormat='C2'}" Width="80"/>
                    <DataGridTextColumn Binding="{Binding RetailPrice, StringFormat='C2'}" Width="80"/>
                    <DataGridTextColumn Binding="{Binding StockQuantity}" Width="70"/>
                    <DataGridTextColumn Binding="{Binding Location}" Width="120"/>
                    <DataGridTextColumn Binding="{Binding Supplier}" Width="150"/>
                    <DataGridTemplateColumn Width="100" Header="">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border BorderBrush="Gray" BorderThickness="1" Background="White" Width="80" Height="50" Margin="2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ImagePath}" Value="">
                                                    <Setter Property="Border.Background" Value="LightGray"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ImagePath}" Value="{x:Null}">
                                                    <Setter Property="Border.Background" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Image Source="{Binding ImagePath}" Stretch="Uniform" Margin="5">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ImagePath}" Value="">
                                                        <Setter Property="Image.Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
        </Grid>
    </DockPanel>
</Window>
