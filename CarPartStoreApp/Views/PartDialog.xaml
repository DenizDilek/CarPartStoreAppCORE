<Window x:Class="CarPartStoreApp.Views.PartDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding DialogTitleAdd}"
        Height="750"
        Width="850"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#1A202C"
        TextElement.Foreground="#E2E8F0"
        WindowStyle="None"
        AllowsTransparency="True">
    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="32"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False"
            NonClientFrameEdges="None"
            GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <!-- Dark Theme Color Scheme -->
        <SolidColorBrush x:Key="HeaderBrush" Color="#2D3748"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#4A5568"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#1A202C"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#2D3748"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#4A5568"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#3D4654"/>
        <SolidColorBrush x:Key="PressedBrush" Color="#4A5568"/>
        <SolidColorBrush x:Key="TextBrush" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#A0AEC0"/>

        <!-- Primary Button Style (Dark Theme) -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#3182CE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4299E1"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#4A5568"/>
                    <Setter Property="Foreground" Value="#A0AEC0"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary Button Style (Dark Theme) -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#2D3748"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#4A5568"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D4654"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#1A202C"/>
                    <Setter Property="BorderBrush" Value="#2D3748"/>
                    <Setter Property="Foreground" Value="#4A5568"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox Style (Dark Theme) -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1A202C"/>
            <Setter Property="BorderBrush" Value="#4A5568"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#E2E8F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3182CE"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox Style (Dark Theme) -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#1A202C"/>
            <Setter Property="BorderBrush" Value="#4A5568"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="IsEditable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"
                                                      Margin="0"/>
                                    <ToggleButton Grid.Column="1"
                                                  x:Name="ArrowButton"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  ClickMode="Press"
                                                  Focusable="False"
                                                  Padding="8,0,4,0"
                                                  Cursor="Hand"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <Path x:Name="Arrow"
                                              Width="10"
                                              Height="6"
                                              Fill="#A0AEC0"
                                              Stretch="Uniform"
                                              Data="M0,0 L5,6 L10,0"/>
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border x:Name="ArrowButtonBorder"
                                                                    Background="{TemplateBinding Background}"
                                                                    Padding="{TemplateBinding Padding}"
                                                                    Cursor="{TemplateBinding Cursor}"
                                                                    CornerRadius="0,6,6,0">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#2D3748" TargetName="ArrowButtonBorder"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <!-- Popup for dropdown -->
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="False"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="PopupBorder"
                                        Background="#2D3748"
                                        BorderBrush="#4A5568"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="4"
                                        MaxHeight="200"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3182CE" TargetName="Border"/>
                                <Setter Property="BorderThickness" Value="2" TargetName="Border"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Fill" Value="#E2E8F0" TargetName="Arrow"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter Property="Fill" Value="#3182CE" TargetName="Arrow"/>
                                <Setter Property="BorderBrush" Value="#3182CE" TargetName="Border"/>
                                <Setter Property="BorderThickness" Value="2" TargetName="Border"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#E2E8F0"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBorder"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}"
                                            CornerRadius="4"
                                            Margin="2">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3D4654" TargetName="ItemBorder"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#3182CE" TargetName="ItemBorder"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DatePicker Style (Dark Theme) -->
        <Style x:Key="ModernDatePicker" TargetType="DatePicker">
            <Setter Property="Background" Value="#1A202C"/>
            <Setter Property="BorderBrush" Value="#4A5568"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <Grid>
                                <DatePickerTextBox x:Name="PART_TextBox"
                                                   Margin="4,0"
                                                   Style="{StaticResource ModernTextBox}"
                                                   BorderThickness="0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3182CE"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label Style (Dark Theme) -->
        <Style x:Key="ModernLabel" TargetType="Label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <!-- GroupBox Style (Dark Theme) -->
        <Style x:Key="ModernGroupBox" TargetType="GroupBox">
            <Setter Property="Background" Value="#2D3748"/>
            <Setter Property="BorderBrush" Value="#4A5568"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.2" BlurRadius="8" ShadowDepth="2"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <ContentPresenter Grid.Row="0" ContentSource="Header" Margin="8,0,8,12"/>
                                <ContentPresenter Grid.Row="1"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GroupBox Header Style (Dark Theme) -->
        <Style x:Key="GroupBoxHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>

        <!-- ScrollBar Style (Dark Theme with Rounded Corners) -->
        <Style x:Key="ModernScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="MinWidth" Value="10"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Margin="0,2,0,2">
                                <Track.Thumb>
                                    <Thumb MinWidth="10">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder"
                                                        Background="#4A5568"
                                                        CornerRadius="5"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#5A6578" TargetName="ThumbBorder"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Horizontal ScrollBar Style (Dark Theme with Rounded Corners) -->
        <Style x:Key="ModernHorizontalScrollBar" TargetType="ScrollBar" BasedOn="{StaticResource ModernScrollBar}">
            <Setter Property="MinHeight" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="False"
                                   Margin="2,0,2,0">
                                <Track.Thumb>
                                    <Thumb MinHeight="10">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder"
                                                        Background="#4A5568"
                                                        CornerRadius="5"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#5A6578" TargetName="ThumbBorder"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Implicit ScrollBar Style - applies to all ScrollBar controls by default -->
        <!-- We use a trigger-based approach instead of BasedOn to handle orientation properly -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="MinWidth" Value="10"/>
                    <Setter Property="Width" Value="10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid>
                                    <Track x:Name="PART_Track"
                                           IsDirectionReversed="True"
                                           Margin="0,2,0,2">
                                        <Track.Thumb>
                                            <Thumb MinWidth="10">
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border x:Name="ThumbBorder"
                                                                Background="#4A5568"
                                                                CornerRadius="5"/>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#5A6578" TargetName="ThumbBorder"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="MinHeight" Value="10"/>
                    <Setter Property="Height" Value="10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid>
                                    <Track x:Name="PART_Track"
                                           IsDirectionReversed="False"
                                           Margin="2,0,2,0">
                                        <Track.Thumb>
                                            <Thumb MinHeight="10">
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border x:Name="ThumbBorder"
                                                                Background="#4A5568"
                                                                CornerRadius="5"/>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#5A6578" TargetName="ThumbBorder"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Custom Window Style with Dark Title Bar -->
        <Style x:Key="CustomWindowStyle" TargetType="Window">
            <Setter Property="Background" Value="#1A202C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Window">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="#2D3748"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="32"/>  <!-- Title bar height -->
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <!-- Custom Title Bar -->
                                <Grid Grid.Row="0" Background="#2D3748">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Window Title -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Title, RelativeSource={RelativeSource TemplatedParent}}"
                                               Foreground="#FFFFFF"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,1"/>
                                    <!-- Window Control Buttons (Minimize, Maximize, Close) -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button x:Name="MinimizeButton"
                                                Width="46"
                                                Height="32"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="#E2E8F0"
                                                WindowChrome.IsHitTestVisibleInChrome="True"
                                                Click="Minimize_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            Width="46"
                                                            Height="32"
                                                            CornerRadius="0">
                                                        <TextBlock Text="─"
                                                                   FontSize="10"
                                                                   Foreground="#E2E8F0"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#3D4654"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button x:Name="MaximizeButton"
                                                Width="46"
                                                Height="32"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="#E2E8F0"
                                                WindowChrome.IsHitTestVisibleInChrome="True"
                                                Click="Maximize_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            Width="46"
                                                            Height="32"
                                                            CornerRadius="0">
                                                        <TextBlock Text="□"
                                                                   FontSize="10"
                                                                   Foreground="#E2E8F0"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#3D4654"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button x:Name="CloseButton"
                                                Width="46"
                                                Height="32"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="#E2E8F0"
                                                WindowChrome.IsHitTestVisibleInChrome="True"
                                                Click="Close_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            Width="46"
                                                            Height="32"
                                                            CornerRadius="0,8,0,0">
                                                        <TextBlock Text="✕"
                                                                   FontSize="10"
                                                                   Foreground="#E2E8F0"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#E53E3E"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                                <!-- Window Content -->
                                <ContentPresenter Grid.Row="1"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollViewer Style (Dark Theme) -->
        <Style x:Key="ModernScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Background" Value="#1A202C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter Grid.Column="0" Grid.Row="0"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Column="1"
                                       Orientation="Vertical"
                                       Style="{StaticResource ModernScrollBar}"/>
                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                       Grid.Row="1"
                                       Orientation="Horizontal"
                                       Style="{StaticResource ModernHorizontalScrollBar}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Custom Title Bar -->
        <Border DockPanel.Dock="Top" Background="#2D3748" Height="32" x:Name="TitleBar">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Window Icon -->
                <Image Grid.Column="0"
                       Source="pack://application:,,,/CarPartStoreApp;component/Icon.png"
                       Width="16"
                       Height="16"
                       Margin="12,0,8,0"
                       VerticalAlignment="Center"/>
                <!-- Window Title -->
                <TextBlock Grid.Column="1"
                           Text="{Binding Title}"
                           Foreground="#FFFFFF"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,0,1"/>
                <!-- Window Control Buttons (Minimize, Maximize, Close) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="MinimizeButton"
                            Width="46"
                            Height="32"
                            BorderThickness="0"
                            Foreground="#E2E8F0"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Focusable="False"
                            Click="Minimize_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ButtonBorder"
                                                    Background="{TemplateBinding Background}"
                                                    Width="46"
                                                    Height="32"
                                                    CornerRadius="0">
                                                <TextBlock Text="─"
                                                           FontSize="14"
                                                           Foreground="#FFFFFF"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,0,4"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" TargetName="ButtonBorder" Value="#3D4654"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="MaximizeButton"
                            Width="46"
                            Height="32"
                            BorderThickness="0"
                            Foreground="#E2E8F0"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Focusable="False"
                            Click="Maximize_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ButtonBorder"
                                                    Background="{TemplateBinding Background}"
                                                    Width="46"
                                                    Height="32"
                                                    CornerRadius="0">
                                                <TextBlock Text="□"
                                                           FontSize="10"
                                                           Foreground="#FFFFFF"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" TargetName="ButtonBorder" Value="#3D4654"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="CloseButton"
                            Width="46"
                            Height="32"
                            BorderThickness="0"
                            Foreground="#E2E8F0"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Focusable="False"
                            Click="Close_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ButtonBorder"
                                                    Background="{TemplateBinding Background}"
                                                    Width="46"
                                                    Height="32"
                                                    CornerRadius="0">
                                                <TextBlock Text="✕"
                                                           FontSize="12"
                                                           Foreground="#FFFFFF"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" TargetName="ButtonBorder" Value="#E53E3E"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Card with ScrollViewer -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0"
                      Style="{StaticResource ModernScrollViewer}">
            <Border Background="#2D3748"
                    BorderBrush="#4A5568"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="24,24,24,0"
                    Padding="24">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.2" BlurRadius="12" ShadowDepth="2"/>
                </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Two Column Section for Basic Info -->
                <GroupBox Grid.Row="0" Style="{StaticResource ModernGroupBox}" Margin="0,0,0,16">
                    <GroupBox.Header>
                        <TextBlock Text="Basic Information" Style="{StaticResource GroupBoxHeaderStyle}"/>
                    </GroupBox.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Part Number and Name Row -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0" Content="{Binding LabelPartNumber}" Style="{StaticResource ModernLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding Part.PartNumber}" Style="{StaticResource ModernTextBox}" ToolTip="{Binding ToolTipPartNumber}"/>

                            <Label Grid.Column="2" Content="{Binding LabelName}" Style="{StaticResource ModernLabel}"/>
                            <TextBox Grid.Column="3" Text="{Binding Part.Name}" Style="{StaticResource ModernTextBox}" ToolTip="{Binding ToolTipName}"/>
                        </Grid>

                        <!-- Description Row (Full Width) -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,0">
                            <Label Content="{Binding LabelDescription}" Width="140" Style="{StaticResource ModernLabel}"/>
                            <TextBox Text="{Binding Part.Description}" Width="560" Style="{StaticResource ModernTextBox}" ToolTip="{Binding ToolTipDescription}"/>
                        </StackPanel>

                        <!-- Category Row -->
                        <Grid Grid.Row="2" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0" Content="{Binding LabelCategory}" Style="{StaticResource ModernLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Categories}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding Part.CategoryId}"
                                      Style="{StaticResource ModernComboBox}"/>
                        </Grid>

                        <!-- Brand and Model Row -->
                        <Grid Grid.Row="3" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0" Content="{Binding LabelBrand}" Style="{StaticResource ModernLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding Part.Brand}" Style="{StaticResource ModernTextBox}" ToolTip="{Binding ToolTipBrand}"/>

                            <Label Grid.Column="2" Content="{Binding LabelModel}" Style="{StaticResource ModernLabel}"/>
                            <TextBox Grid.Column="3" Text="{Binding Part.Model}" Style="{StaticResource ModernTextBox}"/>
                        </Grid>

                        <!-- ReleaseDate Row -->
                        <Grid Grid.Row="4" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0" Content="{Binding LabelReleaseDate}" Style="{StaticResource ModernLabel}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding Part.ReleaseDate, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                     Width="200"
                                     HorizontalAlignment="Left"
                                     Style="{StaticResource ModernTextBox}"/>
                        </Grid>
                    </Grid>
                </GroupBox>

                <!-- Pricing Section -->
                <GroupBox Grid.Row="1" Style="{StaticResource ModernGroupBox}" Margin="0,0,0,16">
                    <GroupBox.Header>
                        <TextBlock Text="Pricing Information" Style="{StaticResource GroupBoxHeaderStyle}"/>
                    </GroupBox.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Grid.Column="0" Content="{Binding LabelCostPrice}" Style="{StaticResource ModernLabel}"/>
                        <TextBox Grid.Column="1" Text="{Binding Part.CostPrice, StringFormat='F2'}" Width="200" HorizontalAlignment="Left" Style="{StaticResource ModernTextBox}" ToolTip="{Binding ToolTipCostPrice}"/>
                    </Grid>
                </GroupBox>

                <!-- Inventory Section -->
                <GroupBox Grid.Row="2" Style="{StaticResource ModernGroupBox}" Margin="0,0,0,16">
                    <GroupBox.Header>
                        <TextBlock Text="Inventory Information" Style="{StaticResource GroupBoxHeaderStyle}"/>
                    </GroupBox.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Grid.Column="0" Content="{Binding LabelStockQuantity}" Style="{StaticResource ModernLabel}"/>
                        <TextBox Grid.Column="1" Text="{Binding Part.StockQuantity}" Width="200" HorizontalAlignment="Left" Style="{StaticResource ModernTextBox}" ToolTip="{Binding ToolTipStockQuantity}"/>

                        <Label Grid.Column="2" Content="{Binding LabelLocation}" Style="{StaticResource ModernLabel}"/>
                        <TextBox Grid.Column="3" Text="{Binding Part.Location}" Style="{StaticResource ModernTextBox}" ToolTip="{Binding ToolTipLocation}"/>
                    </Grid>
                </GroupBox>

                <!-- Image Section (Multiple Images Support - Up to 6) -->
                <GroupBox Grid.Row="3" Style="{StaticResource ModernGroupBox}">
                    <GroupBox.Header>
                        <TextBlock Text="{Binding LabelImage}" Style="{StaticResource GroupBoxHeaderStyle}"/>
                    </GroupBox.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Image Gallery (6 images max) -->
                        <ItemsControl Grid.Row="0" x:Name="ImageGallery" ItemsSource="{Binding PartImages}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#4A5568"
                                            BorderThickness="1"
                                            Background="#1A202C"
                                            Width="100"
                                            Height="80"
                                            Margin="4"
                                            CornerRadius="4">
                                        <Grid>
                                            <Image Source="{Binding ImageSource}"
                                                   Stretch="Uniform"
                                                   Margin="4">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ImageSource}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <!-- Remove Button Overlay -->
                                            <Button Content="X"
                                                    Width="20"
                                                    Height="20"
                                                    FontSize="10"
                                                    FontWeight="Bold"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Margin="0,-8,-8,0"
                                                    Click="RemoveImage_Click"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding RemoveButtonVisibility}"
                                                    Cursor="Hand">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="#E53E3E"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            CornerRadius="10"
                                                                            Width="20"
                                                                            Height="20">
                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                                          VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#C53030"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Image Buttons -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0" HorizontalAlignment="Left">
                            <Button Content="{Binding ButtonUploadImage}"
                                    Width="140"
                                    Height="36"
                                    Margin="0,0,12,0"
                                    Click="UploadImage_Click"
                                    Style="{StaticResource ModernButton}"
                                    ToolTip="{Binding ToolTipImage}"/>
                            <Button Content="{Binding ButtonRemoveAllImages}"
                                    Width="160"
                                    Height="36"
                                    Margin="0"
                                    Click="RemoveAllImages_Click"
                                    Visibility="{Binding RemoveImagesVisibility}"
                                    Style="{StaticResource SecondaryButton}"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Button Section -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,24">
                    <Button Content="{Binding ButtonSave}"
                            Width="120"
                            Height="36"
                            Margin="0,0,12,0"
                            Click="Save_Click"
                            IsDefault="True"
                            Style="{StaticResource ModernButton}"/>
                    <Button Content="{Binding ButtonCancel}"
                            Width="120"
                            Height="36"
                            Margin="0"
                            Click="Cancel_Click"
                            IsCancel="True"
                            Style="{StaticResource SecondaryButton}"/>
                </StackPanel>
            </Grid>
        </Border>
        </ScrollViewer>
    </DockPanel>
</Window>
